spring.application.name=shopify-analytics
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.url=jdbc:postgresql://localhost:5432/shopify_analytics
spring.datasource.username=postgres
spring.datasource.password=CHANGE_ME

spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=true

# Shopify app credentials (kept on backend; do NOT send client_secret from frontend)
shopify.client-id=CHANGE_ME
shopify.client-secret=CHANGE_ME
